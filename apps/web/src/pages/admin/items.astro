---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { createSupabaseServerClient } from '@/lib/supabase';
import { itemsService } from '@/services/items';
import { itemFormSchema } from '@/schemas/item';
import type { Item } from '@/schemas/item';
import { z } from 'zod';

const supabase = createSupabaseServerClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();

let items: Item[] = [];
let formErrors: Record<string, string> = {};
let actionError = '';
let successMessage = '';

// Load items
if (session?.access_token) {
  try {
    items = await itemsService.list(session.access_token);
  } catch (e) {
    actionError = e instanceof Error ? e.message : 'Erreur de chargement';
  }
}

// Handle POST actions (create / update / delete)
if (Astro.request.method === 'POST' && session?.access_token) {
  const form = await Astro.request.formData();
  const action = form.get('_action') as string;

  try {
    if (action === 'delete') {
      const id = z.string().uuid().parse(form.get('id'));
      await itemsService.remove(session.access_token, id);
      successMessage = 'Item supprimé.';
      items = await itemsService.list(session.access_token);
    } else {
      const parsed = itemFormSchema.safeParse({
        title:       form.get('title'),
        description: form.get('description') || undefined,
        status:      form.get('status'),
      });

      if (!parsed.success) {
        parsed.error.issues.forEach(i => {
          formErrors[i.path[0] as string] = i.message;
        });
      } else {
        if (action === 'create') {
          await itemsService.create(session.access_token, parsed.data);
          successMessage = 'Item créé.';
        } else if (action === 'update') {
          const id = z.string().uuid().parse(form.get('id'));
          await itemsService.update(session.access_token, id, parsed.data);
          successMessage = 'Item mis à jour.';
        }
        items = await itemsService.list(session.access_token);
      }
    }
  } catch (e) {
    actionError = e instanceof Error ? e.message : 'Une erreur est survenue';
  }
}

const STATUS_LABELS: Record<string, string> = {
  todo:        'À faire',
  in_progress: 'En cours',
  done:        'Terminé',
};
const STATUS_COLORS: Record<string, string> = {
  todo:        'bg-yellow-500/15 text-yellow-400',
  in_progress: 'bg-blue-500/15 text-blue-400',
  done:        'bg-green-500/15 text-green-400',
};
---

<AdminLayout title="Items">
  {actionError && (
    <div class="mb-4 px-4 py-3 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-sm">{actionError}</div>
  )}
  {successMessage && (
    <div class="mb-4 px-4 py-3 rounded-lg bg-green-500/10 border border-green-500/20 text-green-400 text-sm">{successMessage}</div>
  )}

  <!-- Create form -->
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-6">
    <h2 class="text-sm font-medium text-gray-200 mb-4">Nouvel item</h2>
    <form method="POST" class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <input type="hidden" name="_action" value="create" />

      <div>
        <input
          name="title" type="text" required placeholder="Titre *"
          class:list={['w-full px-3 py-2 rounded-lg bg-gray-800 border text-sm text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500', formErrors.title ? 'border-red-500' : 'border-gray-700']}
        />
        {formErrors.title && <p class="mt-1 text-xs text-red-400">{formErrors.title}</p>}
      </div>

      <input
        name="description" type="text" placeholder="Description (optionnel)"
        class="w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"
      />

      <div class="flex gap-2">
        <select
          name="status"
          class="flex-1 px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
        >
          <option value="todo">À faire</option>
          <option value="in_progress">En cours</option>
          <option value="done">Terminé</option>
        </select>
        <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium transition-colors">
          Créer
        </button>
      </div>
    </form>
  </div>

  <!-- Items list -->
  {items.length === 0 ? (
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-10 text-center">
      <p class="text-gray-500 text-sm">Aucun item pour l'instant.</p>
    </div>
  ) : (
    <div class="bg-gray-900 border border-gray-800 rounded-xl divide-y divide-gray-800">
      {items.map(item => (
        <details class="group">
          <summary class="flex items-center justify-between px-4 py-3 cursor-pointer list-none">
            <div class="flex items-center gap-3 min-w-0">
              <span class={`shrink-0 text-xs px-2 py-0.5 rounded-full font-medium ${STATUS_COLORS[item.status]}`}>
                {STATUS_LABELS[item.status]}
              </span>
              <span class="text-sm text-gray-200 truncate">{item.title}</span>
            </div>
            <span class="text-gray-600 text-xs ml-3 group-open:rotate-90 transition-transform">▶</span>
          </summary>

          <!-- Edit form (revealed on expand) -->
          <div class="px-4 pb-4 pt-2 bg-gray-950/50">
            <form method="POST" class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              <input type="hidden" name="_action" value="update" />
              <input type="hidden" name="id" value={item.id} />

              <input
                name="title" type="text" required value={item.title}
                class="w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
              />
              <input
                name="description" type="text" value={item.description ?? ''}
                placeholder="Description (optionnel)"
                class="w-full px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500"
              />

              <div class="flex gap-2">
                <select
                  name="status"
                  class="flex-1 px-3 py-2 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
                >
                  {['todo', 'in_progress', 'done'].map(s => (
                    <option value={s} selected={item.status === s}>{STATUS_LABELS[s]}</option>
                  ))}
                </select>
                <button type="submit" class="px-3 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-medium transition-colors">
                  Sauvegarder
                </button>
              </div>
            </form>

            <form method="POST" class="mt-2">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={item.id} />
              <button
                type="submit"
                class="text-xs text-red-500 hover:text-red-400 transition-colors"
                onclick="return confirm('Supprimer cet item ?')"
              >
                Supprimer
              </button>
            </form>
          </div>
        </details>
      ))}
    </div>
  )}
</AdminLayout>

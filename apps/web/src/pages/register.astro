---
import { createSupabaseServerClient } from '@/lib/supabase';
import { z } from 'zod';

const supabase = createSupabaseServerClient(Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (user) return Astro.redirect('/admin');

const registerSchema = z.object({
  fullName: z.string().min(1, 'Nom requis'),
  email:    z.string().email('Email invalide'),
  password: z.string().min(6, 'Minimum 6 caractères'),
});

let errors: Record<string, string> = {};
let success = false;
let registeredEmail = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const parsed = registerSchema.safeParse({
    fullName: form.get('fullName'),
    email:    form.get('email'),
    password: form.get('password'),
  });

  if (!parsed.success) {
    parsed.error.issues.forEach(i => {
      errors[i.path[0] as string] = i.message;
    });
  } else {
    const { data, error } = await supabase.auth.signUp({
      email:    parsed.data.email,
      password: parsed.data.password,
      options:  { data: { full_name: parsed.data.fullName } },
    });
    if (error) {
      errors.root = error.message;
    } else if (data.user && !data.session) {
      success = true;
      registeredEmail = parsed.data.email;
    } else {
      return Astro.redirect('/admin');
    }
  }
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Créer un compte — Admin</title>
    <style>@import "tailwindcss";</style>
  </head>
  <body class="min-h-screen bg-gray-950 flex items-center justify-center p-4">
    <div class="w-full max-w-sm">

      {success ? (
        <div class="text-center">
          <div class="text-3xl mb-3">✉️</div>
          <h1 class="text-xl font-semibold text-white">Vérifiez votre email</h1>
          <p class="text-sm text-gray-400 mt-2">
            Un lien de confirmation a été envoyé à <strong class="text-white">{registeredEmail}</strong>.
          </p>
          <a href="/login" class="mt-6 inline-block text-sm text-indigo-400 hover:text-indigo-300">
            Retour à la connexion
          </a>
        </div>
      ) : (
        <>
          <div class="text-center mb-8">
            <div class="text-3xl mb-3">⚡</div>
            <h1 class="text-xl font-semibold text-white">Créer un compte</h1>
            <p class="text-sm text-gray-400 mt-1">Accès à l'espace d'administration</p>
          </div>

          {errors.root && (
            <div class="mb-4 px-4 py-3 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-sm">
              {errors.root}
            </div>
          )}

          <form method="POST" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5" for="fullName">Nom complet</label>
              <input
                id="fullName" name="fullName" type="text" autocomplete="name" required
                class:list={['w-full px-3.5 py-2.5 rounded-lg bg-gray-900 border text-sm text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500', errors.fullName ? 'border-red-500' : 'border-gray-700']}
                placeholder="Jean Dupont"
              />
              {errors.fullName && <p class="mt-1 text-xs text-red-400">{errors.fullName}</p>}
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5" for="email">Email</label>
              <input
                id="email" name="email" type="email" autocomplete="email" required
                class:list={['w-full px-3.5 py-2.5 rounded-lg bg-gray-900 border text-sm text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500', errors.email ? 'border-red-500' : 'border-gray-700']}
                placeholder="vous@exemple.com"
              />
              {errors.email && <p class="mt-1 text-xs text-red-400">{errors.email}</p>}
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5" for="password">Mot de passe</label>
              <input
                id="password" name="password" type="password" autocomplete="new-password" required
                class:list={['w-full px-3.5 py-2.5 rounded-lg bg-gray-900 border text-sm text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500', errors.password ? 'border-red-500' : 'border-gray-700']}
                placeholder="Minimum 6 caractères"
              />
              {errors.password && <p class="mt-1 text-xs text-red-400">{errors.password}</p>}
            </div>

            <button
              type="submit"
              class="w-full py-2.5 px-4 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-gray-950"
            >
              Créer mon compte
            </button>
          </form>

          <p class="mt-6 text-center text-sm text-gray-500">
            Déjà un compte ? <a href="/login" class="text-indigo-400 hover:text-indigo-300">Se connecter</a>
          </p>
        </>
      )}
    </div>
  </body>
</html>

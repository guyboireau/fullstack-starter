---
import { createSupabaseServerClient } from '@/lib/supabase';

interface Props {
  title: string;
}

const { title } = Astro.props;
const supabase = createSupabaseServerClient(Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();

const navItems = [
  { label: 'Dashboard', href: '/admin', icon: '▤' },
  { label: 'Items',     href: '/admin/items', icon: '☰' },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Admin</title>
    <style>
      @import "tailwindcss";
    </style>
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen flex">

    <!-- Sidebar -->
    <aside class="w-56 shrink-0 bg-gray-900 border-r border-gray-800 flex flex-col">
      <div class="px-6 py-5 border-b border-gray-800">
        <span class="font-semibold text-indigo-400 text-sm tracking-widest uppercase">Admin</span>
      </div>

      <nav class="flex-1 px-3 py-4 space-y-1">
        {navItems.map(item => (
          <a
            href={item.href}
            class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-gray-400 hover:text-white hover:bg-gray-800 transition-colors"
          >
            <span class="text-base">{item.icon}</span>
            {item.label}
          </a>
        ))}
      </nav>

      <div class="px-4 py-4 border-t border-gray-800">
        <p class="text-xs text-gray-500 truncate mb-3">{user?.email}</p>
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="w-full text-left text-xs text-gray-500 hover:text-red-400 transition-colors"
          >
            Se déconnecter
          </button>
        </form>
      </div>
    </aside>

    <!-- Main content -->
    <div class="flex-1 flex flex-col min-w-0">
      <header class="h-14 border-b border-gray-800 flex items-center px-6">
        <h1 class="text-sm font-medium text-gray-200">{title}</h1>
      </header>

      <main class="flex-1 p-6">
        <slot />
      </main>
    </div>

  </body>
</html>
